# .env.example
# Copy this file to `.env` and fill in your values.
# Promptlytics reads these automatically if you use python-dotenv,
# but you can also paste the API key directly into the Gradio UI.

# Optional: Your OpenAI API key.
# Leave blank (or omit) to use the built-in rule-based "mock LLM".
OPENAI_API_KEY=sk-...
